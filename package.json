{
  "name": "sentinel",
  "version": "1.0.0",
  "description": "[![License: MIT](https://img.shields.io/badge/License-MIT-red.svg)](https://opensource.org/licenses/MIT)\r [![Ecosystem: Stellar/EVM](https://img.shields.io/badge/Ecosystem-Stellar%20%7C%20EVM-purple.svg)](https://stellar.org)\r [![Security: Real--Time](https://img.shields.io/badge/Security-Real--Time%20Monitoring-orange.svg)](#)",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:ci": "npm run test -- --ci --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:build": "docker-compose build",
    "docker:clean": "docker-compose down -v",
    "docker:db:migrate": "docker-compose exec backend npx prisma migrate deploy",
    "docker:db:migrate:dev": "docker-compose exec backend npx prisma migrate dev",
    "docker:db:reset": "docker-compose exec backend npx prisma migrate reset",
    "docker:db:studio": "docker-compose exec backend npx prisma studio",
    "docker:ps": "docker-compose ps"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sentinel-security-productions/Sentinel.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sentinel-security-productions/Sentinel/issues"
  },
  "homepage": "https://github.com/sentinel-security-productions/Sentinel#readme",
  "dependencies": {
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "axios": "^1.17.0",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "typeorm": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}
