{
  "name": "sentinel",
  "version": "1.0.0",
  "description": "[![License: MIT](https://img.shields.io/badge/License-MIT-red.svg)](https://opensource.org/licenses/MIT)\r [![Ecosystem: Stellar/EVM](https://img.shields.io/badge/Ecosystem-Stellar%20%7C%20EVM-purple.svg)](https://stellar.org)\r [![Security: Real--Time](https://img.shields.io/badge/Security-Real--Time%20Monitoring-orange.svg)](#)",
  "main": "index.js",
  "scripts": {
    "build": "npm run prisma:generate && npm run build:backend",
    "build:backend": "tsc --project apps/backend/tsconfig.app.json",
    "build:dashboard": "tsc --project apps/dashboard/tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "test": "npm run test:backend && npm run test:dashboard",
    "test:backend": "jest --config jest.backend.config.js",
    "test:dashboard": "jest --config jest.dashboard.config.js",
    "test:ci": "npm run test -- --ci --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "db:migrate": "bash scripts/migrate.sh deploy",
    "db:migrate:dev": "bash scripts/migrate-dev.sh",
    "db:migrate:new": "bash scripts/migrate.sh create-only",
    "db:status": "bash scripts/migrate.sh status",
    "db:rollback:guide": "bash scripts/rollback.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:build": "docker-compose build",
    "docker:clean": "docker-compose down -v",
    "docker:db:migrate": "docker-compose exec backend npx prisma migrate deploy",
    "docker:db:migrate:dev": "docker-compose exec backend npx prisma migrate dev",
    "docker:db:reset": "docker-compose exec backend npx prisma migrate reset",
    "docker:db:studio": "docker-compose exec backend npx prisma studio",
    "docker:ps": "docker-compose ps",
    "prepare": "husky || true",
    "lint-staged": "lint-staged"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sentinel-security-productions/Sentinel.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sentinel-security-productions/Sentinel/issues"
  },
  "homepage": "https://github.com/sentinel-security-productions/Sentinel#readme",
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^7.8.0",
    "@types/react": "^19.2.17",
    "axios": "^1.17.0",
    "ethers": "^6.17.0",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "typeorm": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@nestjs/testing": "^11.1.27",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/tests/**/*.test.ts"
    ]
  }
}
